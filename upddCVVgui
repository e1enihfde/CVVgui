local CVVgui = {}
CVVgui.Connections = {}
CVVgui.IsInteracting = false

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local MarketplaceService = game:GetService("MarketplaceService")

local tweenInfoFast = TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local tweenInfoBack = TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
local tweenInfoSmooth = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local notifGui
local notifContainer

local function getNotifContainer()
    if notifContainer and notifContainer.Parent then
        return notifContainer
    end
    notifGui = Instance.new("ScreenGui")
    notifGui.Name = "CVVgui_Notifs"
    notifGui.ResetOnSpawn = false
    pcall(function() notifGui.Parent = game:GetService("CoreGui") end)
    if not notifGui.Parent then 
        notifGui.Parent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui") 
    end

    notifContainer = Instance.new("Frame", notifGui)
    notifContainer.Size = UDim2.new(0, 250, 1, -20)
    notifContainer.Position = UDim2.new(1, -260, 0, 10)
    notifContainer.BackgroundTransparency = 1

    local layout = Instance.new("UIListLayout", notifContainer)
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.VerticalAlignment = Enum.VerticalAlignment.Bottom
    layout.Padding = UDim.new(0, 8)

    return notifContainer
end

function CVVgui:Notify(titleText, contentText, duration)
    duration = duration or 3
    local container = getNotifContainer()

    local frame = Instance.new("CanvasGroup", container)
    frame.Size = UDim2.new(1, 0, 0, 50)
    frame.Position = UDim2.new(1, 50, 0, 0)
    frame.BackgroundColor3 = Color3.fromRGB(16, 16, 16)
    frame.BorderColor3 = Color3.fromRGB(50, 50, 50)
    frame.BorderSizePixel = 1
    frame.GroupTransparency = 1

    local accent = Instance.new("Frame", frame)
    accent.Size = UDim2.new(0, 2, 1, 0)
    accent.BackgroundColor3 = Color3.fromRGB(80, 160, 255)
    accent.BorderSizePixel = 0

    local title = Instance.new("TextLabel", frame)
    title.Size = UDim2.new(1, -16, 0, 20)
    title.Position = UDim2.new(0, 12, 0, 6)
    title.BackgroundTransparency = 1
    title.Text = titleText or "Notification"
    title.TextColor3 = Color3.fromRGB(235, 235, 235)
    title.Font = Enum.Font.Code
    title.TextSize = 13
    title.TextXAlignment = Enum.TextXAlignment.Left

    local desc = Instance.new("TextLabel", frame)
    desc.Size = UDim2.new(1, -16, 0, 18)
    desc.Position = UDim2.new(0, 12, 0, 26)
    desc.BackgroundTransparency = 1
    desc.Text = contentText or ""
    desc.TextColor3 = Color3.fromRGB(160, 160, 160)
    desc.Font = Enum.Font.Code
    desc.TextSize = 12
    desc.TextXAlignment = Enum.TextXAlignment.Left

    TweenService:Create(frame, tweenInfoSmooth, {Position = UDim2.new(0, 0, 0, 0), GroupTransparency = 0}):Play()

    task.delay(duration, function()
        if frame and frame.Parent then
            local hideTween = TweenService:Create(frame, tweenInfoFast, {Position = UDim2.new(1, 50, 0, 0), GroupTransparency = 1})
            hideTween:Play()
            hideTween.Completed:Connect(function()
                frame:Destroy()
            end)
        end
    end)
end

function CVVgui:CreateWindow(titleText, toggleKey)
    toggleKey = toggleKey or Enum.KeyCode.RightControl

    local successInfo, gameInfo = pcall(function()
        return MarketplaceService:GetProductInfo(game.PlaceId)
    end)
    local gameName = (successInfo and gameInfo and gameInfo.Name) or game.Name

    task.delay(0.4, function()
        self:Notify("System", "Game: " .. gameName, 4)
    end)

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "CVVgui_Main"
    screenGui.ResetOnSpawn = false
    
    local success = pcall(function() screenGui.Parent = game:GetService("CoreGui") end)
    if not success then screenGui.Parent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui") end

    local normalPos = UDim2.new(0.5, -180, 0.5, -150)
    local hiddenPos = UDim2.new(0.5, -180, 0.5, -100)

    local mainFrame = Instance.new("Frame", screenGui)
    mainFrame.Size = UDim2.new(0, 360, 0, 300)
    mainFrame.Position = hiddenPos
    mainFrame.BackgroundColor3 = Color3.fromRGB(12, 12, 12)
    mainFrame.BorderColor3 = Color3.fromRGB(45, 45, 45)
    mainFrame.BorderSizePixel = 1
    mainFrame.Active = true
    mainFrame.BackgroundTransparency = 1

    local topAccent = Instance.new("Frame", mainFrame)
    topAccent.Size = UDim2.new(1, 0, 0, 2)
    topAccent.BackgroundColor3 = Color3.fromRGB(80, 160, 255)
    topAccent.BorderSizePixel = 0

    local title = Instance.new("TextLabel", mainFrame)
    title.Size = UDim2.new(1, 0, 0, 25)
    title.Position = UDim2.new(0, 0, 0, 2)
    title.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    title.BorderColor3 = Color3.fromRGB(40, 40, 40)
    title.BorderSizePixel = 1
    title.Text = "  " .. titleText
    title.TextColor3 = Color3.fromRGB(235, 235, 235)
    title.Font = Enum.Font.Code
    title.TextSize = 14
    title.TextXAlignment = Enum.TextXAlignment.Left

    local tabBar = Instance.new("Frame", mainFrame)
    tabBar.Size = UDim2.new(1, -12, 0, 26)
    tabBar.Position = UDim2.new(0, 6, 0, 32)
    tabBar.BackgroundTransparency = 1

    local tabLayout = Instance.new("UIListLayout", tabBar)
    tabLayout.FillDirection = Enum.FillDirection.Horizontal
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabLayout.Padding = UDim.new(0, 4)

    local contentArea = Instance.new("Frame", mainFrame)
    contentArea.Size = UDim2.new(1, -12, 1, -70)
    contentArea.Position = UDim2.new(0, 6, 0, 64)
    contentArea.BackgroundTransparency = 1

    local isOpen = true
    local isAnimating = false

    local function toggleUI()
        if isAnimating then return end
        isAnimating = true

        if isOpen then
            local t = TweenService:Create(mainFrame, tweenInfoFast, {Position = hiddenPos, BackgroundTransparency = 1})
            t:Play()
            t.Completed:Connect(function()
                mainFrame.Visible = false
                isAnimating = false
            end)
            isOpen = false
        else
            mainFrame.Visible = true
            local t = TweenService:Create(mainFrame, tweenInfoBack, {Position = normalPos, BackgroundTransparency = 0})
            t:Play()
            t.Completed:Connect(function()
                isAnimating = false
            end)
            isOpen = true
        end
    end

    TweenService:Create(mainFrame, tweenInfoBack, {Position = normalPos, BackgroundTransparency = 0}):Play()

    local dragging, dragInput, dragStart, startPos
    mainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and not CVVgui.IsInteracting then
            dragging = true 
            dragStart = input.Position 
            startPos = mainFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    mainFrame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
    end)
    table.insert(self.Connections, UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging and not CVVgui.IsInteracting then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            normalPos = mainFrame.Position
        end
    end))

    table.insert(self.Connections, UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == toggleKey then
            toggleUI()
        end
    end))

    local windowObj = {
        ScreenGui = screenGui,
        MainFrame = mainFrame,
        ContentArea = contentArea,
        TabBar = tabBar,
        Tabs = {}
    }

    function windowObj:CreateTab(tabName)
        local tabBtn = Instance.new("TextButton", windowObj.TabBar)
        tabBtn.Size = UDim2.new(0, 85, 1, 0)
        tabBtn.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
        tabBtn.BorderColor3 = Color3.fromRGB(40, 40, 40)
        tabBtn.BorderSizePixel = 1
        tabBtn.Text = tabName
        tabBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
        tabBtn.Font = Enum.Font.Code
        tabBtn.TextSize = 12

        local tabContainer = Instance.new("ScrollingFrame", windowObj.ContentArea)
        tabContainer.Size = UDim2.new(1, 0, 1, 0)
        tabContainer.BackgroundTransparency = 1
        tabContainer.BorderSizePixel = 0
        tabContainer.ScrollBarThickness = 3
        tabContainer.ScrollBarImageColor3 = Color3.fromRGB(60, 60, 60)
        tabContainer.Visible = false

        local containerLayout = Instance.new("UIListLayout", tabContainer)
        containerLayout.SortOrder = Enum.SortOrder.LayoutOrder
        containerLayout.Padding = UDim.new(0, 6)

        containerLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            tabContainer.CanvasSize = UDim2.new(0, 0, 0, containerLayout.AbsoluteContentSize.Y + 10)
        end)

        local function activate()
            for _, t in ipairs(windowObj.Tabs) do
                t.Container.Visible = false
                t.Button.TextColor3 = Color3.fromRGB(150, 150, 150)
                t.Button.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
            end
            tabContainer.Visible = true
            tabBtn.TextColor3 = Color3.fromRGB(235, 235, 235)
            tabBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        end

        tabBtn.MouseButton1Click:Connect(activate)

        table.insert(windowObj.Tabs, {Button = tabBtn, Container = tabContainer})

        if #windowObj.Tabs == 1 then
            activate()
        end

        return tabContainer
    end

    return windowObj
end

function CVVgui:CreateButton(parent, text, callback)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, -6, 0, 30)
    btn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    btn.BorderColor3 = Color3.fromRGB(45, 45, 45)
    btn.BorderSizePixel = 1
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(210, 210, 210)
    btn.Font = Enum.Font.Code
    btn.TextSize = 13

    table.insert(self.Connections, btn.MouseButton1Click:Connect(function()
        if callback then callback() end
    end))
end

function CVVgui:CreateToggle(parent, text, defaultState, callback)
    local enabled = defaultState or false

    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, -6, 0, 30)
    btn.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    btn.BorderColor3 = Color3.fromRGB(45, 45, 45)
    btn.BorderSizePixel = 1
    btn.Text = "  " .. text .. ": " .. (enabled and "[ ON ]" or "[ OFF ]")
    btn.TextColor3 = enabled and Color3.fromRGB(240, 240, 240) or Color3.fromRGB(140, 140, 140)
    btn.Font = Enum.Font.Code
    btn.TextSize = 13
    btn.TextXAlignment = Enum.TextXAlignment.Left

    table.insert(self.Connections, btn.MouseButton1Click:Connect(function()
        enabled = not enabled
        btn.Text = "  " .. text .. ": " .. (enabled and "[ ON ]" or "[ OFF ]")
        btn.TextColor3 = enabled and Color3.fromRGB(240, 240, 240) or Color3.fromRGB(140, 140, 140)
        if callback then callback(enabled) end
    end))
end

function CVVgui:CreateSlider(parent, text, minVal, maxVal, defaultVal, callback)
    local sliderFrame = Instance.new("Frame", parent)
    sliderFrame.Size = UDim2.new(1, -6, 0, 45)
    sliderFrame.BackgroundColor3 = Color3.fromRGB(16, 16, 16)
    sliderFrame.BorderColor3 = Color3.fromRGB(45, 45, 45)
    sliderFrame.BorderSizePixel = 1

    local label = Instance.new("TextLabel", sliderFrame)
    label.Size = UDim2.new(1, -10, 0, 20)
    label.Position = UDim2.new(0, 5, 0, 2)
    label.BackgroundTransparency = 1
    label.Text = text .. ": " .. tostring(defaultVal)
    label.TextColor3 = Color3.fromRGB(210, 210, 210)
    label.Font = Enum.Font.Code
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left

    local track = Instance.new("Frame", sliderFrame)
    track.Size = UDim2.new(1, -10, 0, 10)
    track.Position = UDim2.new(0, 5, 0, 26)
    track.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    track.BorderColor3 = Color3.fromRGB(40, 40, 40)
    track.BorderSizePixel = 1

    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new((defaultVal - minVal) / (maxVal - minVal), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(80, 160, 255)
    fill.BorderSizePixel = 0

    local isDragging = false

    local function update(input)
        local pos = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local value = math.floor(minVal + (maxVal - minVal) * pos)
        fill.Size = UDim2.new(pos, 0, 1, 0)
        label.Text = text .. ": " .. tostring(value)
        if callback then callback(value) end
    end

    table.insert(self.Connections, track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isDragging = true
            CVVgui.IsInteracting = true
            update(input)
        end
    end))

    table.insert(self.Connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            isDragging = false
            CVVgui.IsInteracting = false
        end
    end))

    table.insert(self.Connections, UserInputService.InputChanged:Connect(function(input)
        if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            update(input)
        end
    end))
end

function CVVgui:CreateDropdown(parent, text, options, defaultOpt, callback)
    options = options or {}
    local selected = defaultOpt or options[1] or ""
    
    local dropdownFrame = Instance.new("Frame", parent)
    dropdownFrame.Size = UDim2.new(1, -6, 0, 30)
    dropdownFrame.BackgroundColor3 = Color3.fromRGB(16, 16, 16)
    dropdownFrame.BorderColor3 = Color3.fromRGB(45, 45, 45)
    dropdownFrame.BorderSizePixel = 1
    dropdownFrame.ClipsDescendants = true

    local headerBtn = Instance.new("TextButton", dropdownFrame)
    headerBtn.Size = UDim2.new(1, 0, 0, 30)
    headerBtn.BackgroundTransparency = 1
    headerBtn.Text = "  " .. text .. ": " .. tostring(selected) .. "  v"
    headerBtn.TextColor3 = Color3.fromRGB(210, 210, 210)
    headerBtn.Font = Enum.Font.Code
    headerBtn.TextSize = 12
    headerBtn.TextXAlignment = Enum.TextXAlignment.Left

    local listFrame = Instance.new("Frame", dropdownFrame)
    listFrame.Size = UDim2.new(1, 0, 0, #options * 24)
    listFrame.Position = UDim2.new(0, 0, 0, 30)
    listFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    listFrame.BorderColor3 = Color3.fromRGB(45, 45, 45)
    listFrame.BorderSizePixel = 1

    local listLayout = Instance.new("UIListLayout", listFrame)
    listLayout.SortOrder = Enum.SortOrder.LayoutOrder

    local isOpen = false

    local function toggle()
        isOpen = not isOpen
        local targetSize = isOpen and UDim2.new(1, -6, 0, 30 + #options * 24) or UDim2.new(1, -6, 0, 30)
        TweenService:Create(dropdownFrame, tweenInfoFast, {Size = targetSize}):Play()
    end

    headerBtn.MouseButton1Click:Connect(toggle)

    for _, opt in ipairs(options) do
        local optBtn = Instance.new("TextButton", listFrame)
        optBtn.Size = UDim2.new(1, 0, 0, 24)
        optBtn.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        optBtn.BorderColor3 = Color3.fromRGB(35, 35, 35)
        optBtn.BorderSizePixel = 1
        optBtn.Text = "  " .. tostring(opt)
        optBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
        optBtn.Font = Enum.Font.Code
        optBtn.TextSize = 12
        optBtn.TextXAlignment = Enum.TextXAlignment.Left

        optBtn.MouseButton1Click:Connect(function()
            selected = opt
            headerBtn.Text = "  " .. text .. ": " .. tostring(selected) .. "  v"
            toggle()
            if callback then callback(selected) end
        end)
    end
end

function CVVgui:CreateInput(parent, text, placeholderText, callback)
    local inputFrame = Instance.new("Frame", parent)
    inputFrame.Size = UDim2.new(1, -6, 0, 32)
    inputFrame.BackgroundColor3 = Color3.fromRGB(16, 16, 16)
    inputFrame.BorderColor3 = Color3.fromRGB(45, 45, 45)
    inputFrame.BorderSizePixel = 1

    local label = Instance.new("TextLabel", inputFrame)
    label.Size = UDim2.new(0.5, -5, 1, 0)
    label.Position = UDim2.new(0, 5, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = text
    label.TextColor3 = Color3.fromRGB(210, 210, 210)
    label.Font = Enum.Font.Code
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left

    local textBox = Instance.new("TextBox", inputFrame)
    textBox.Size = UDim2.new(0.5, -5, 1, -6)
    textBox.Position = UDim2.new(0.5, 0, 0, 3)
    textBox.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    textBox.BorderColor3 = Color3.fromRGB(40, 40, 40)
    textBox.BorderSizePixel = 1
    textBox.Text = ""
    textBox.PlaceholderText = placeholderText or "Type here..."
    textBox.TextColor3 = Color3.fromRGB(230, 230, 230)
    textBox.PlaceholderColor3 = Color3.fromRGB(100, 100, 100)
    textBox.Font = Enum.Font.Code
    textBox.TextSize = 12

    table.insert(self.Connections, textBox.FocusLost:Connect(function(enterPressed)
        if callback then callback(textBox.Text, enterPressed) end
    end))
end

function CVVgui:CreateLabel(parent, text)
    local label = Instance.new("TextLabel", parent)
    label.Size = UDim2.new(1, -6, 0, 22)
    label.BackgroundTransparency = 1
    label.Text = "  " .. text
    label.TextColor3 = Color3.fromRGB(160, 160, 160)
    label.Font = Enum.Font.Code
    label.TextSize = 12
    label.TextXAlignment = Enum.TextXAlignment.Left
    return label
end

function CVVgui:Unload(windowObj)
    for _, conn in ipairs(self.Connections) do
        if conn.Connected then conn:Disconnect() end
    end
    table.clear(self.Connections)
    if windowObj and windowObj.ScreenGui then windowObj.ScreenGui:Destroy() end
    if notifGui then notifGui:Destroy() end
end

return CVVgui
